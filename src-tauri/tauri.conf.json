{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "AeroForge Control",
  "version": "0.1.0",
  "identifier": "com.noah.aeroforgecontrol",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm.cmd run dev",
    "beforeBuildCommand": "npm.cmd run build"
  },
  "app": {
    "windows": [
      {
        "title": "AeroForge Control",
        "width": 1460,
        "height": 980,
        "minWidth": 1180,
        "minHeight": 760,
        "center": true,
        "decorations": true,
        "transparent": false,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
