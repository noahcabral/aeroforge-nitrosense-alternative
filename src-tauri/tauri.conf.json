{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "AeroForge Control",
  "version": "0.13.5",
  "identifier": "com.noah.aeroforgecontrol",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "powershell -ExecutionPolicy Bypass -File scripts/Run-FrontendDev.ps1",
    "beforeBuildCommand": "powershell -ExecutionPolicy Bypass -File scripts/Run-FrontendBuild.ps1",
    "beforeBundleCommand": "powershell -ExecutionPolicy Bypass -File scripts/Prepare-BundleResources.ps1"
  },
  "app": {
    "windows": [
      {
        "title": "AeroForge Control",
        "width": 1460,
        "height": 980,
        "minWidth": 1180,
        "minHeight": 760,
        "center": true,
        "visible": false,
        "decorations": true,
        "transparent": false,
        "resizable": true,
        "fullscreen": false,
        "additionalBrowserArgs": "--disable-features=msWebOOUI,msPdfOOUI,msSmartScreenProtection --disable-gpu --disable-gpu-compositing"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "resources": {},
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper",
        "silent": true
      },
      "nsis": {
        "installMode": "perMachine",
        "minimumWebview2Version": "124.0.2478.67",
        "installerHooks": "installer-hooks.nsh"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
